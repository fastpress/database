{
    "name": "fastpress/database",
    "description": "A simple database abstraction layer for PHP applications",
    "type": "library",
    "require": {
        "php": "^8.0",
        "ext-pdo": "*"
    },
    "scripts": {
        "test": "phpunit",
        "fix-style": "phpcbf --standard=PSR12 src/",
        "lint": "phpcs --standard=PSR12 src/",
        "analyze": "phpstan analyse src/"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.6",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Fastpress\\Memory\\": "src/Memory/"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Samayo",
            "email": "samayo@pm.me"
        }
    ],
    "keywords": [
        "database",
        "pdo",
        "php",
        "fastpress",
        "orm",
        "framework"
    ],
    "homepage": "https://github.com/fastpress/database",
    "support": {
        "issues": "https://github.com/fastpress/database/issues",
        "source": "https://github.com/fastpress/database"
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.0"
        }
    },
    "minimum-stability": "stable"
}
